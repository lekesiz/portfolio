# ========================================
# Environment Variables - Portfolio Website
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ========================================
# Website Configuration
# ========================================
# Your production domain (without trailing slash)
VITE_SITE_URL=https://yourdomain.com

# Default language (fr, en, or tr)
VITE_DEFAULT_LANGUAGE=fr

# ========================================
# Analytics (Optional)
# ========================================
# Google Analytics Measurement ID
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics
# VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# ========================================
# Error Tracking (Optional)
# ========================================
# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ========================================
# Contact Form (Optional)
# ========================================
# EmailJS Service ID (if using EmailJS for contact form)
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=

# Formspree Form ID (alternative to EmailJS)
# VITE_FORMSPREE_FORM_ID=

# ========================================
# API Keys (Optional)
# ========================================
# If you're using any third-party services
# VITE_API_KEY=

# ========================================
# Feature Flags (Optional)
# ========================================
# Enable/disable features
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_CONTACT_FORM=true
# VITE_ENABLE_CV_DOWNLOAD=true

# ========================================
# Social Media (Optional)
# ========================================
# Override social media links from code
# VITE_GITHUB_URL=https://github.com/yourusername
# VITE_LINKEDIN_URL=https://linkedin.com/in/yourusername
# VITE_TWITTER_URL=https://x.com/yourusername

# ========================================
# Notes
# ========================================
# - All variables must start with VITE_ to be accessible in the app
# - Changes require dev server restart (npm run dev)
# - Don't store sensitive data here in production
